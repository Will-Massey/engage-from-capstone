generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum BillingCycle {
  FIXED_DATE
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
  ONE_TIME
}

enum VATRate {
  ZERO
  REDUCED_5
  STANDARD_20
  EXEMPT
}

enum UserRole {
  ADMIN
  PARTNER
  MD
  MANAGER
  SENIOR
  JUNIOR
}

enum CompanyType {
  SOLE_TRADER
  PARTNERSHIP
  LIMITED_COMPANY
  LLP
  CHARITY
  NON_PROFIT
}

enum MTDITSAStatus {
  NOT_REQUIRED
  ELIGIBLE
  MANDATORY
  OPTED_IN
  EXEMPT
  REQUIRED_2026
  REQUIRED_2027
  REQUIRED_2028
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
  WITHDRAWN
  ARCHIVED
  LOST
}

enum ApprovalStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum DeclineReason {
  PRICE
  SCOPE
  TIMING
  COMPETITOR
  OTHER
}

enum PricingFrequency {
  ONE_TIME
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

// New: How to display prices clearly
enum PriceDisplayMode {
  PER_MONTH      // £71/month
  PER_QUARTER    // £213/quarter
  PER_YEAR       // £850/year
  ONE_TIME       // £500 one-time
  PER_HOUR       // £75/hour
  PER_UNIT       // £10/unit
}

enum ServiceCategory {
  COMPLIANCE
  ADVISORY
  TAX
  PAYROLL
  BOOKKEEPING
  AUDIT
  CONSULTING
  TECHNICAL
  SPECIALIZED
}

enum PricingModel {
  FIXED
  HOURLY
  TIERED
  CUSTOM
  PER_EMPLOYEE
  PER_TRANSACTION
}

enum CoverLetterTone {
  PROFESSIONAL
  FRIENDLY
  MODERN
}

// ==================== CLIENT TOUCHPOINT / LIFECYCLE ====================

enum ClientRelationship {
  NEW
  EXISTING
}

enum AmlStatus {
  NOT_STARTED
  PENDING
  CLEAR
  REFER
  FAILED
}

enum ClientLifecycleStage {
  PROSPECT
  PROPOSAL_ACCEPTED
  AML_PENDING
  AML_COMPLETE
  ENGAGEMENT_LETTER_SENT
  ENGAGEMENT_LETTER_SIGNED
  INFO_REQUESTED
  INFO_RECEIVED
  ONBOARDING_SETUP
  KICKOFF_SENT
  MILESTONE_CHECK_IN
  SATISFACTION_CHECK
  ONGOING
  ANNUAL_REVIEW
}

enum TouchpointStatus {
  PENDING
  SENT
  SKIPPED
  PAUSED
}

enum TouchpointTriggerType {
  EVENT
  TIME_DELAY
}

enum TouchpointChannel {
  EMAIL
  SMS
  IN_APP
}

enum TouchpointTone {
  WARM
  NEUTRAL
  URGENT
}

enum EmailMessageType {
  PROPOSAL
  ACCEPTANCE
  TOUCHPOINT
  RENEWAL
  FOLLOW_UP
  TEST
  OTHER
}

enum EmailProvider {
  SENDGRID
  SMTP
  GMAIL
  OUTLOOK
  MICROSOFT365
}

enum EmailDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  BOUNCED
  FAILED
  SUPPRESSED
}

// ==================== TENANT MODELS ====================

model FirmGroup {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  ownerTenantId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownerTenant Tenant?  @relation("FirmGroupOwner", fields: [ownerTenantId], references: [id], onDelete: SetNull)
  tenants     Tenant[] @relation("FirmGroupMembers")

  @@index([slug])
  @@index([ownerTenantId])
}

model Tenant {
  id             String   @id @default(uuid())
  subdomain      String   @unique
  name           String
  logo           String?
  primaryColor   String   @default("#0ea5e9")
  secondaryColor String   @default("#0284c7")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Multi-firm workspace (W4.3)
  firmGroupId     String?
  firmGroup       FirmGroup?  @relation("FirmGroupMembers", fields: [firmGroupId], references: [id], onDelete: SetNull)
  ownedFirmGroups FirmGroup[] @relation("FirmGroupOwner")

  // Settings stored as JSON string
  settings String @default("{}")

  // VAT Settings
  vatRegistered Boolean @default(true)
  vatNumber     String?
  defaultVatRate VATRate @default(STANDARD_20)
  autoApplyVat   Boolean @default(true)

  // Stripe / Subscription (Stripe legacy — Revolut primary)
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  subscriptionStatus    String?
  subscriptionTier      String?
  trialEndsAt           DateTime?
  lastPaymentStatus     String?
  lastPaymentDate       DateTime?
  revolutCustomerId     String?  @map("revolut_customer_id")
  revolutOrderId        String?  @map("revolut_order_id")

  // Relations
  users                 User[]
  clients               Client[]
  proposals             Proposal[]
  services              ServiceTemplate[]
  pricingRules          PricingRule[]
  templates             ProposalTemplate[]
  coverLetterTemplates  CoverLetterTemplate[]
  activityLogs          ActivityLog[]
  touchpointTemplates   TouchpointTemplate[]
  touchpoints           Touchpoint[]
  emailLogs             EmailLog[]
  emailSuppressions     EmailSuppression[]
  paymentSplits         PaymentSplit[]
  payoutSettings        TenantPayoutSettings?

  @@index([subdomain])
  @@index([isActive])
  @@index([stripeCustomerId])
  @@index([firmGroupId])
}

// ==================== USER MODELS ====================

model User {
  id            String    @id @default(uuid())
  email         String
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  jobTitle      String?
  role          UserRole  @default(JUNIOR)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  emailVerified DateTime?
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Security
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String? // Encrypted TOTP secret
  deletedAt        DateTime?

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  createdProposals   Proposal[]            @relation("CreatedProposals")
  approvedProposals  Proposal[]            @relation("ApprovedProposals")
  activityLogs       ActivityLog[]
  refreshTokens      RefreshToken[]
  passwordResets     PasswordReset[]
  twoFactorBackupCodes TwoFactorBackupCode[]

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([role])
  @@index([deletedAt])
}

model PasswordReset {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model TwoFactorBackupCode {
  id        String    @id @default(uuid())
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ==================== CLIENT MODELS ====================

model Client {
  id              String       @id @default(uuid())
  name            String
  companyType     CompanyType  @default(SOLE_TRADER)
  contactEmail    String
  contactPhone    String?
  contactName     String?

  // Company details
  companyNumber String?
  utr           String?
  vatNumber     String?
  vatRegistered Boolean @default(false)

  // Address stored as JSON string
  address String?

  // MTD ITSA
  mtditsaStatus   MTDITSAStatus @default(NOT_REQUIRED)
  mtditsaIncome   Float?
  mtditsaEligible Boolean @default(false)

  // Business info
  industry      String?
  employeeCount Int?
  turnover      Float?
  yearEnd       String?

  // New win vs existing client (renewal/upsell) — used by Clara
  clientRelationship ClientRelationship @default(NEW)

  // Metadata
  notes    String?
  tags     String @default("") // Comma-separated tags
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Tenant relation
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Client portal
  portalToken      String? @unique
  portalTokenExpiry DateTime?
  portalEnabled    Boolean @default(false)

  // Client Lifecycle & Touchpoints (automated onboarding workflow)
  lifecycleStage     ClientLifecycleStage @default(PROSPECT)
  touchpointsPaused  Boolean              @default(false)
  marketingConsent   Boolean              @default(false)

  // Key compliance / deadline dates (used for deadline-driven touchpoints)
  nextVatDueDate                 DateTime?
  nextAccountsDueDate            DateTime?
  nextConfirmationStatementDue DateTime?
  amlCompletedAt                 DateTime?
  amlSubmittedAt                 DateTime?
  amlSubmissionData              String?  // JSON: client AML self-service form
  amlStatus                      AmlStatus @default(NOT_STARTED)
  amlCheckedAt                   DateTime?
  amlProviderRef                 String?
  engagementLetterSentAt         DateTime?
  engagementLetterSignedAt       DateTime?

  // Relations
  proposals Proposal[]
  touchpoints Touchpoint[]
  emailLogs   EmailLog[]

  @@unique([tenantId, contactEmail])
  @@index([tenantId])
  @@index([companyType])
  @@index([mtditsaStatus])
  @@index([lifecycleStage])
  @@index([clientRelationship])
  @@index([amlStatus])
  @@index([amlProviderRef])
}

// ==================== PROPOSAL MODELS ====================

model Proposal {
  id              String         @id @default(uuid())
  reference       String         @unique
  title           String
  status          ProposalStatus @default(DRAFT)

  // Partner approval workflow (junior drafts → partner approves before send)
  approvalStatus          ApprovalStatus @default(NONE)
  submittedForApprovalAt  DateTime?
  approvedAt              DateTime?
  approvedById            String?
  approvedBy              User?          @relation("ApprovedProposals", fields: [approvedById], references: [id], onDelete: SetNull)
  approvalNotes           String?
  rejectionReason         String?

  // Dates
  validUntil        DateTime  // Proposal expiry date
  contractStartDate DateTime? // When the contract/service begins
  sentAt            DateTime?
  viewedAt          DateTime?
  acceptedAt        DateTime?
  declinedAt        DateTime?
  declinedBy        String?
  declineReason     DeclineReason?
  declineReasonText String?
  /// AI reclassification when declineReason=OTHER and free text provided
  declineReasonAi   DeclineReason?
  expiredAt         DateTime?
  
  // Renewal tracking
  renewalDate          DateTime?
  renewalReminderSent  Boolean   @default(false)
  renewalReminderSentAt DateTime?
  isRenewal            Boolean   @default(false)
  originalProposalId   String?
  /// Renewal or replacement quote that superseded this proposal
  supersededById       String?
  archivedAt           DateTime?
  
  // Acceptance notification
  acceptanceNotifiedAt DateTime?

  // Pricing — integer pence (docs/money-int-pence-migration.md, Stage 2:
  // pence authoritative; wire format converts to pounds at the API boundary)
  discountType   String?
  discountValue  Float   @default(0)
  vatRate        Float   @default(20)

  subtotalPence       Int @default(0)
  discountAmountPence Int @default(0)
  vatAmountPence      Int @default(0)
  totalPence          Int @default(0)

  // Payment terms
  paymentTerms     String           @default("7 days")
  paymentFrequency PricingFrequency @default(MONTHLY)

  // Content
  coverLetter      String?
  /// Client-facing narrative — services, benefits, positive NLP (AI-generated, editable)
  proposalSummary  String?
  terms            String?
  notes            String?
  customFields     String @default("{}")

  // UK Compliant Engagement Letter
  engagementLetter String?
  termsAccepted    Boolean   @default(false)
  termsAcceptedAt  DateTime?

  // Acceptance
  acceptedBy        String?
  acceptedByIp      String?
  signatoryPosition String?
  signature    String?

  // Sharing & Public Access
  shareToken        String?   @unique
  shareTokenExpiry  DateTime?
  publicAccessEnabled Boolean @default(false)

  // Email Tracking
  lastEmailedAt  DateTime?
  emailHistory   String @default("[]")

  // Payment tracking (Revolut / GoCardless stub)
  paymentId            String?
  paymentMandateId     String?
  paymentProvider      String?   // revolut, gocardless_stub
  paymentStatus        String?   // NOT_STARTED, PENDING, ACTIVE, COMPLETED, PAID, FAILED, CANCELLED, SKIPPED, DISPUTED, DISPUTE_LOST, REFUNDED
  paymentUrl           String?
  paymentMethod        String?   // card, open_banking, direct_debit
  paidAt               DateTime?
  paymentFailureReason String?
  stripeSubscriptionId String?   // set when a recurring (subscription-mode) checkout completes

  // Client payment authorisation (Revolut checkout)
  paymentAuthAccepted   Boolean   @default(false) @map("payment_auth_accepted")
  paymentAuthAcceptedAt DateTime? @map("payment_auth_accepted_at")
  paymentAuthVersion    String?   @map("payment_auth_version")
  engagementLetterAccepted   Boolean   @default(false) @map("engagement_letter_accepted")
  engagementLetterAcceptedAt DateTime? @map("engagement_letter_accepted_at")

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("CreatedProposals", fields: [createdById], references: [id])

  services     ProposalService[]
  activityLogs ActivityLog[]
  documents    ProposalDocument[]
  views        ProposalView[]
  signatures   ProposalSignature[]
  paymentSplits PaymentSplit[]
  emailLogs    EmailLog[]

  @@index([tenantId])
  @@index([clientId])
  @@index([status])
  @@index([approvalStatus])
  @@index([approvedById])
  @@index([reference])
  @@index([shareToken])
  @@index([paymentId])
  @@index([createdAt])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, sentAt])
  @@index([tenantId, status, renewalDate])
  @@index([tenantId, validUntil])
}

// Capstone platform fee + agency share ledger (client proposal payments)
model PaymentSplit {
  id                   String   @id @default(uuid())
  revolutOrderId       String   @unique @map("revolut_order_id")
  idempotencyKey       String?  @unique @map("idempotency_key")
  totalPence           Int      @map("total_pence")
  platformFeePence     Int      @map("platform_fee_pence")
  processorFeePence    Int      @default(0) @map("processor_fee_pence")
  processorMarkupPence Int      @default(0) @map("processor_markup_pence")
  agencySharePence     Int      @map("agency_share_pence")
  platformFeeBps       Int      @map("platform_fee_bps")
  currency             String   @default("GBP")
  payoutStatus         String   @default("PENDING") @map("payout_status") // PENDING, SCHEDULED, TRANSFERRED, MANUAL, FAILED, HELD
  payoutTransferId     String?  @map("payout_transfer_id")
  payoutFailureReason  String?  @map("payout_failure_reason")
  paidAt               DateTime @default(now()) @map("paid_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  proposalId String   @map("proposal_id")
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([tenantId])
  @@map("payment_splits")
}

model TenantPayoutSettings {
  id                    String    @id @default(uuid())
  tenantId              String    @unique @map("tenant_id")
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enabled               Boolean   @default(false)
  enabledAt             DateTime? @map("enabled_at")
  enabledByUserId       String?   @map("enabled_by_user_id")
  consentVersion        String?   @map("consent_version")
  consentAcceptedAt     DateTime? @map("consent_accepted_at")
  consentIp             String?   @map("consent_ip")
  payoutMethod          String    @default("STRIPE_CONNECT") @map("payout_method")
  accountHolderName     String?   @map("account_holder_name")
  stripeConnectedAccountId String?  @map("stripe_connected_account_id")
  stripeTransfersStatus    String   @default("inactive") @map("stripe_transfers_status")
  platformFeeBpsOverride Int?     @map("platform_fee_bps_override")
  verificationStatus    String    @default("PENDING") @map("verification_status")
  verifiedAt            DateTime? @map("verified_at")
  firstPayoutHeldUntil  DateTime? @map("first_payout_held_until")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("tenant_payout_settings")
}

model ProposalService {
  id          String @id @default(uuid())
  name        String
  description String?

  // Clear Pricing - What the client sees. Money is integer pence
  // (docs/money-int-pence-migration.md, Stage 2); wire format converts to
  // pounds at the API boundary.
  billingFrequency BillingCycle   @default(MONTHLY)  // How often billed
  priceDisplayMode PriceDisplayMode @default(PER_MONTH)  // How to show it

  // Quantity and calculations
  quantity        Float @default(1)
  discountPercent Float @default(0)

  // VAT (per line)
  vatRate   Float @default(20)

  displayPricePence     Int                // Price as shown (e.g., 7100 or 85000)
  unitPricePence        Int                // Legacy: per-unit price
  annualEquivalentPence Int @default(0)    // Annual equivalent for comparison
  lineTotalPence        Int                // displayPrice × quantity - discount
  vatAmountPence        Int @default(0)
  grossTotalPence       Int @default(0)

  // Legacy (kept for compatibility)
  frequency  PricingFrequency @default(MONTHLY)
  isOptional Boolean @default(false)

  // Metadata
  sortOrder Int @default(0)

  /// When this one-off charge is due (only meaningful for ONE_TIME lines)
  oneOffDueDate DateTime?

  // Relations
  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  serviceTemplateId String?
  serviceTemplate   ServiceTemplate? @relation(fields: [serviceTemplateId], references: [id])

  @@index([proposalId])
  @@index([billingFrequency])
}

model ProposalDocument {
  id         String   @id @default(uuid())
  name       String
  fileUrl    String
  fileType   String
  fileSize   Int
  uploadedAt DateTime @default(now())

  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
}

// Proposal View Tracking
model ProposalView {
  id        String   @id @default(uuid())
  viewedAt  DateTime @default(now())
  ipAddress String?
  userAgent String?
  viewDuration Int?  // Duration in seconds
  completed Boolean  @default(false)
  viewerId  String? // User ID when viewed in-app (authenticated)

  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([viewedAt])
  @@index([viewerId])
}

// Electronic Signature (UK Compliant)
model ProposalSignature {
  id        String   @id @default(uuid())
  signedBy  String
  signedByRole String
  signerEmail String?
  signatureData String? // Base64 encoded signature image (legacy)
  signatureFilePath String? // Path to PNG file (new)
  signedAt  DateTime @default(now())
  ipAddress String?
  userAgent String?   // Browser/device fingerprint
  deviceInfo String?  // Device type, OS, screen size
  geoLocation String? // Approximate location from IP
  documentHash String? // SHA-256 of proposal content at signing
  termsHash String?    // SHA-256 of terms shown at signing
  consentText String?  // Exact consent statement accepted
  signatureType String @default("SIMPLE_ELECTRONIC")
  agreementVersion String
  agreementAccepted Boolean

  proposalId String
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([signedAt])
}

// ==================== SERVICE TEMPLATE MODELS ====================

model ServiceTemplate {
  id              String @id @default(uuid())
  category        ServiceCategory
  subcategory     String?
  name            String
  description     String
  longDescription String?

  // Pricing - New Clear System
  priceAmount     Float           @default(0)  // The actual price (e.g., 71 or 850)
  priceDisplayMode PriceDisplayMode @default(PER_MONTH)  // How to show it (PER_MONTH, PER_YEAR, etc)
  billingCycle    BillingCycle    @default(MONTHLY)  // How often to bill
  
  // Legacy fields (kept for compatibility)
  basePrice       Float           @default(0)
  baseHours       Float           @default(1)
  pricingModel    PricingModel    @default(FIXED)
  vatRate         VATRate         @default(STANDARD_20)
  isVatApplicable Boolean         @default(true)
  fixedBillingDate DateTime?
  billingDayOfMonth Int?          // 1-31 for monthly billing
  annualEquivalent Float?         // Annual cost for monthly calculation
  frequencyOptions String         @default("MONTHLY,QUARTERLY,ANNUALLY")
  defaultFrequency PricingFrequency @default(MONTHLY)

  // Complexity stored as JSON string
  complexityFactors String @default("[]")

  // Requirements and deliverables stored as JSON strings
  requirements String @default("[]")
  deliverables String @default("[]")

  // UK Compliance
  applicableEntityTypes String @default("LIMITED_COMPANY,SOLE_TRADER")
  regulatoryNotes       String?

  // Metadata
  tags      String  @default("")
  isActive  Boolean @default(true)
  isPopular Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  proposalServices ProposalService[]
  pricingRules     PricingRule[]

  @@index([tenantId])
  @@index([category])
  @@index([isActive])
}

// ==================== ENGAGEMENT LIBRARY VERSIONING ====================

model EngagementLibraryVersion {
  id           String   @id @default(uuid())
  versionLabel String   @unique // e.g. "2026.1"
  publishedAt  DateTime @default(now())
  changelog    String   @default("")
  clausesJson  String   // JSON snapshot of EngagementClause[]
  isCurrent    Boolean  @default(false)
  createdAt    DateTime @default(now())

  proposalTemplates    ProposalTemplate[]
  coverLetterTemplates CoverLetterTemplate[]

  @@index([isCurrent])
  @@index([publishedAt])
}

// ==================== PROPOSAL TEMPLATE MODELS ====================

model ProposalTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?

  // Target
  targetEntityType String?
  targetIndustry   String?

  // Content
  title String
  coverLetter String?
  terms       String?

  // Services included stored as JSON string
  serviceConfig String @default("[]")

  // Pricing defaults stored as JSON string
  defaultPricing String @default("{}")

  // Usage
  usageCount Int?
  lastUsedAt DateTime?

  // Engagement library versioning (OverSuite-style)
  engagementLibraryVersionId String?
  engagementLibraryVersion   EngagementLibraryVersion? @relation(fields: [engagementLibraryVersionId], references: [id], onDelete: SetNull)
  needsUpdate                Boolean @default(false)

  // Metadata
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdById String?

  @@index([tenantId])
  @@index([isDefault])
  @@index([targetEntityType])
  @@index([needsUpdate])
  @@index([engagementLibraryVersionId])
}

model CoverLetterTemplate {
  id          String          @id @default(uuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  tone        CoverLetterTone @default(PROFESSIONAL)
  content     String          // Template content with {{mergeFields}}
  isDefault   Boolean         @default(false)
  isSystem    Boolean         @default(false)  // Pre-designed templates
  createdById String?

  // Engagement library versioning (OverSuite-style)
  engagementLibraryVersionId String?
  engagementLibraryVersion   EngagementLibraryVersion? @relation(fields: [engagementLibraryVersionId], references: [id], onDelete: SetNull)
  needsUpdate                Boolean @default(false)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([tenantId])
  @@index([isDefault])
  @@index([needsUpdate])
  @@index([engagementLibraryVersionId])
}

// ==================== PRICING RULE MODELS ====================

model PricingRule {
  id          String @id @default(uuid())
  name        String
  description String?

  // Condition stored as JSON string
  conditionField    String
  conditionOperator String
  conditionValue    String // JSON string

  // Adjustment
  adjustmentType  String
  adjustmentValue Float

  // Application
  priority Int     @default(0)
  isActive Boolean @default(true)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  serviceId String
  service   ServiceTemplate @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([serviceId])
  @@index([isActive])
}

// ==================== ACTIVITY LOG ====================

model ActivityLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String?

  // Details
  description String?
  metadata    String @default("{}")
  ipAddress   String?
  userAgent   String?

  createdAt DateTime @default(now())

  // Relations
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  proposalId String?
  proposal   Proposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([proposalId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
}

// ==================== CLIENT TOUCHPOINT WORKFLOW ====================

model TouchpointTemplate {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  stage         ClientLifecycleStage
  subject       String
  body          String   // Supports merge tags: {{client_name}}, {{contact_name}}, {{practice_name}}, {{next_step}}, {{due_date}}
  tone          TouchpointTone @default(WARM)
  isMarketing   Boolean  @default(false) // If true, only send if client has marketingConsent
  isActive      Boolean  @default(true)  // Global on/off for this stage template

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  touchpoints Touchpoint[]

  @@unique([tenantId, stage])
  @@index([tenantId])
  @@index([stage])
  @@index([isActive])
}

model Touchpoint {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  stage       ClientLifecycleStage
  triggerType TouchpointTriggerType
  scheduledFor DateTime

  status      TouchpointStatus @default(PENDING)
  channel     TouchpointChannel @default(EMAIL)

  templateId  String?
  template    TouchpointTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  sentAt      DateTime?

  requiresHumanApproval Boolean @default(false)

  // Audit / notes
  notes       String?

  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailLogs EmailLog[]

  @@index([clientId])
  @@index([tenantId])
  @@index([status])
  @@index([scheduledFor])
  @@index([requiresHumanApproval])
  @@index([status, scheduledFor])
}

// ==================== EMAIL DELIVERY ====================

model EmailLog {
  id           String              @id @default(uuid())
  tenantId     String
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId     String?
  client       Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  proposalId   String?
  proposal     Proposal?           @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  touchpointId String?
  touchpoint   Touchpoint?         @relation(fields: [touchpointId], references: [id], onDelete: SetNull)

  messageType  EmailMessageType
  provider     EmailProvider
  status       EmailDeliveryStatus @default(QUEUED)

  to           String
  from         String
  replyTo      String?
  subject      String
  externalId   String?
  error        String?
  metadata     String              @default("{}")

  sentAt       DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([tenantId])
  @@index([clientId])
  @@index([proposalId])
  @@index([touchpointId])
  @@index([status])
  @@index([createdAt])
  @@index([externalId])
  @@index([tenantId, createdAt])
}

model EmailSuppression {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email     String
  reason    String
  createdAt DateTime @default(now())

  @@unique([tenantId, email])
  @@index([tenantId])
}
