# Database (Engage docker-compose defaults: engage / engage_dev_password / engage_dev)
DATABASE_URL="postgresql://engage:engage_dev_password@localhost:5432/engage_dev?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# Application
NODE_ENV="development"
PORT=3001
API_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:5173"

# Email — platform SendGrid (default) + optional tenant SMTP/OAuth
SENDGRID_API_KEY=""
SENDGRID_WEBHOOK_VERIFICATION_KEY=""
EMAIL_PLATFORM_FROM="notifications@engage.capstonesoftware.co.uk"
EMAIL_PLATFORM_FROM_NAME="Engage by Capstone"
EMAIL_DEFAULT_REPLY_TO_FALLBACK="support@capstonesoftware.co.uk"

# Optional legacy SMTP (Capstone internal / local testing)
EMAIL_PROVIDER="smtp"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@proposal-platform.co.uk"

# File Upload
MAX_FILE_SIZE="10485760"
UPLOAD_DIR="uploads"

# Multi-tenancy (API host without subdomain, e.g. Render — use demo after seed)
DEFAULT_TENANT_SUBDOMAIN="demo"

# PDF Generation
PDF_LOGO_URL=""
PDF_COMPANY_NAME="UK Proposal Platform"

# HMRC MTD API (Phase 2)
HMRC_CLIENT_ID=""
HMRC_CLIENT_SECRET=""
HMRC_BASE_URL="https://test-api.service.hmrc.gov.uk"

# Companies House API
COMPANIES_HOUSE_API_KEY=your_api_key_here

# Xero OAuth (W1.1–W1.2 — client import + accepted proposal push)
# Register app at https://developer.xero.com/app/manage
# Redirect URI must match XERO_REDIRECT_URI exactly (default: {API_URL}/api/oauth/callback/xero)
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
XERO_REDIRECT_URI="http://localhost:3001/api/oauth/callback/xero"

# OpenAI — production fallback (optional if using xAI)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# xAI (Grok) — preferred for dev/testing (OpenAI-compatible API)
# Get a key at https://console.x.ai — rotate before production go-live
XAI_API_KEY=""
XAI_MODEL="grok-3-mini"
# XAI_BASE_URL="https://api.x.ai/v1"
# AI_PROVIDER="xai"
