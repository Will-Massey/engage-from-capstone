# Database
DATABASE_URL="postgresql://user:password@localhost:5432/uk_proposal_platform"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# Application
NODE_ENV="development"
PORT=3001
API_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:5173"

# Admin / maintenance endpoints (disable in production by default)
# - /api/admin/* uses ADMIN_SECRET_KEY (header: x-admin-key or query: ?key=...)
# - /api/seed-services-public uses PUBLIC_SEED_KEY (query: ?key=...)
# - /api/setup and /api/setup/migrate-pricing are disabled in production unless enabled below
ADMIN_SECRET_KEY=""
PUBLIC_SEED_KEY=""
MIGRATION_SECRET_KEY=""
ENABLE_PUBLIC_SEED="false"
ENABLE_SETUP_ENDPOINT="true"
ALLOW_RENDER_WILDCARD_ORIGINS="false"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@proposal-platform.co.uk"

# File Upload
MAX_FILE_SIZE="10485760"
UPLOAD_DIR="uploads"

# Multi-tenancy
DEFAULT_SUBDOMAIN="app"
SUBDOMAIN_SEPARATOR="."

# PDF Generation
PDF_LOGO_URL=""
PDF_COMPANY_NAME="UK Proposal Platform"

# HMRC MTD API (Phase 2)
HMRC_CLIENT_ID=""
HMRC_CLIENT_SECRET=""
HMRC_BASE_URL="https://test-api.service.hmrc.gov.uk"

# Companies House API
COMPANIES_HOUSE_API_KEY=your_api_key_here
