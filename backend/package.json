{
  "name": "engage-backend",
  "version": "1.0.0",
  "description": "Engage by Capstone - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "npx prisma generate",
    "build": "npx tsc --project tsconfig.json",
    "postbuild": "cp -r src/scripts dist/scripts 2>/dev/null || echo 'No scripts to copy'",
    "start": "node start-prod.mjs",
    "test": "jest --testPathIgnorePatterns=/smoke/",
    "test:integration": "jest tests/smoke",
    "test:watch": "jest --watch",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed-enhanced.ts",
    "db:studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "job:renewal-reminders": "npx tsx scripts/run-renewal-reminders.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@sendgrid/eventwebhook": "^8.0.0",
    "@sendgrid/mail": "^8.1.6",
    "@stripe/stripe-js": "^8.9.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.14.0",
    "qrcode": "^1.5.4",
    "redis": "^5.11.0",
    "speakeasy": "^2.0.0",
    "stripe": "^20.4.0",
    "typescript": "^5.9.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "xero-node": "^18.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.13.3",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "prisma": "5.22.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "author": "Capstone",
  "license": "MIT"
}
