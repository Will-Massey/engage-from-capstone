{
  "name": "engage-backend",
  "version": "1.0.0",
  "description": "Engage by Capstone - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmitOnError false",
