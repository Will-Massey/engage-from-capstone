# =============================================================================
# Engage Environment Configuration
# Copy to .env and fill in values
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/engage_dev

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
API_URL=http://localhost:3001

# Security
JWT_SECRET=change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Redis (optional - remove if not using)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:3001
VITE_APP_ENV=development
VITE_SENTRY_DSN=

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
# SendGrid / Email (platform default — proposals work without tenant SMTP)
SENDGRID_API_KEY=
SENDGRID_WEBHOOK_VERIFICATION_KEY=
EMAIL_PLATFORM_FROM=notifications@engage.capstonesoftware.co.uk
EMAIL_PLATFORM_FROM_NAME=Engage by Capstone
EMAIL_DEFAULT_REPLY_TO_FALLBACK=support@capstonesoftware.co.uk
# Legacy aliases (still read as fallbacks)
EMAIL_FROM=noreply@engage.capstonesoftware.co.uk
EMAIL_FROM_ADDRESS=noreply@engage.capstonesoftware.co.uk

# Stripe (for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Cloudflare R2 / S3 (for file storage)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# OpenAI (for AI features)
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
