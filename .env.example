# =============================================================================
# Engage Environment Configuration
# Copy to .env and fill in values
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/engage_dev

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
API_URL=http://localhost:3001

# Security
JWT_SECRET=change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Redis (optional - remove if not using)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:3001
VITE_APP_ENV=development
VITE_SENTRY_DSN=

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
# Cloudflare Email Service (platform default — proposals work without tenant SMTP)
EMAIL_WORKER_URL=https://capstone-engage-email.william-19a.workers.dev
EMAIL_WORKER_SECRET=
CLOUDFLARE_ACCOUNT_ID=19ad15686e6bd22ab2896661ac1976f1
CLOUDFLARE_EMAIL_API_TOKEN=
EMAIL_PLATFORM_FROM=proposals@capstonesoftware.co.uk
EMAIL_PLATFORM_FROM_NAME=Capstone Engage
EMAIL_FROM_ADDRESS=proposals@capstonesoftware.co.uk
EMAIL_FROM_NAME=Capstone Engage
EMAIL_REPLY_TO=support@capstonesoftware.co.uk
EMAIL_DEFAULT_REPLY_TO_FALLBACK=support@capstonesoftware.co.uk

# Stripe (legacy fallback)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# Revolut Merchant API (primary — agency platform fee + client proposal checkout)
REVOLUT_API_SECRET_KEY=
REVOLUT_API_PUBLIC_KEY=
REVOLUT_WEBHOOK_SECRET=
REVOLUT_API_URL=https://sandbox-merchant.revolut.com

# Platform fee on client payments (basis points: 250 = 2.5%)
ENGAGE_PLATFORM_FEE_BPS=250

# Revolut Business API (agency payout after client payment)
# OAuth (preferred — access tokens expire; refresh automatically):
REVOLUT_BUSINESS_CLIENT_ID=
REVOLUT_BUSINESS_REFRESH_TOKEN=
REVOLUT_BUSINESS_PRIVATE_KEY=
# Or static access token (manual paste — expires ~40 min):
REVOLUT_BUSINESS_API_KEY=
REVOLUT_BUSINESS_API_URL=https://sandbox-b2b.revolut.com
REVOLUT_BUSINESS_ACCOUNT_ID=
ENGAGE_DEFAULT_AGENCY_COUNTERPARTY_ID=

# Cloudflare R2 / S3 (for file storage)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# OpenAI (for AI features)
OPENAI_API_KEY=

# Xero OAuth (Phase W1.1–W1.2)
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3001/api/oauth/callback/xero

# QuickBooks Online OAuth (R4.1)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:3001/api/oauth/callback/quickbooks
# 'false' = production API (quickbooks.api.intuit.com); anything else = sandbox
QUICKBOOKS_SANDBOX=true

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Capstone Superadmin (optional — backend only)
SUPERADMIN_URL=
SUPERADMIN_WEBHOOK_SECRET=
SUPERADMIN_API_KEY=

# -----------------------------------------------------------------------------
# Webhook & test-bypass secrets (required in production)
# -----------------------------------------------------------------------------
# Auth for POST /api/webhooks/email-events (Bearer or X-Webhook-Secret header).
# Production returns 503 on this webhook if unset.
EMAIL_WEBHOOK_SECRET=
# Auth for POST /api/aml/webhook (X-AML-Webhook-Secret header).
# Production returns 503 on this webhook if unset.
AML_WEBHOOK_SECRET=
# Allows X-Test-Mode rate-limit bypass in production only when the request also
# sends X-Test-Mode-Secret with this value. Leave unset to disable bypass in prod.
E2E_BYPASS_SECRET=
